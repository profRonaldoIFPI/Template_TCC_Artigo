% PERSONALIZAÇÃO DA FOLHA DE ROSTO E CABEÇALHO DO ARTIGO
% ========================================================================

\makeatletter

% Cabeçalho do Artigo (impresso após a folha de rosto)
\newcommand{\imprimircabecalhoartigo}{
    \begin{center}
        \vspace*{2cm}
        {\ABNTEXchapterfont\bfseries\Large\MakeUppercase{\imprimirtitulo}}
        
        \ifx\@subtitulo\empty\else
            {\ABNTEXchapterfont\bfseries\large\MakeUppercase{: \@subtitulo}}
        \fi
        
        \vspace{1.5cm}
        
        \begin{flushright}
            {\normalsize\imprimirautor\footnote{\@emailautor}}
            
            \ifx\imprimirorientador\empty\else
                {\normalsize\imprimirorientador\footnote{\@vinculoorientador. E-mail: \@emailorientador}}
            \fi
            
            \ifx\imprimircoorientador\empty\else
                {\normalsize\imprimircoorientador\footnote{\@vinculocoorientador. E-mail: \@emailcoorientador}}
            \fi
        \end{flushright}
        
        \vspace{1cm}
    \end{center}
}

% Redefinição de resumo para artigo (sem quebra de página)
\renewenvironment{resumo}[1][\resumoname]{%
   % \begin{center}\ABNTEXchapterfont\bfseries\MakeUppercase{#1}\end{center}
   \vspace{\onelineskip}
   \noindent\textbf{\MakeUppercase{#1}}
   \begin{SingleSpace}
}{%
   \end{SingleSpace}
   \vspace{\onelineskip}
}

% Redefinição da folha de rosto
\renewcommand{\folhaderostocontent}{
    \begin{center}
        % Nome do autor
        {\ABNTEXchapterfont\normalsize\MakeUppercase{\imprimirautor}}
        
        \vspace*{\fill}
        
        % Título
        {\ABNTEXchapterfont\bfseries\normalsize\MakeUppercase{\imprimirtitulo}}
        \ifx\@subtitulo\empty\else
            {\ABNTEXchapterfont\bfseries\normalsize\MakeUppercase{: \@subtitulo}}
        \fi
        
        \vspace*{\fill}
        
        % Natureza do trabalho
        \abntex@ifnotempty{\imprimirpreambulo}{%
            \hspace{.45\textwidth}
            \begin{minipage}{.5\textwidth}
                \SingleSpacing
                \imprimirpreambulo
                
                \ifx\@areaconcentracao\empty\else
                    \vspace{0.5cm}
                    Área de concentração: \@areaconcentracao
                \fi
                
                \ifx\imprimirorientador\empty\else
                    \vspace{0.5cm}
                    Orientador: \imprimirorientador
                \fi
                
                \abntex@ifnotempty{\imprimircoorientador}{%
                    \vspace{0.5cm}
                    Coorientador: \imprimircoorientador
                }%
            \end{minipage}%
        }%
        
        \vspace*{\fill}
        
        % Local e data
        {\ABNTEXchapterfont\normalsize\MakeUppercase{\imprimirlocal}}
        \par
        {\ABNTEXchapterfont\normalsize\imprimirdata}
    \end{center}
}
\makeatother

